# =============================================
# 🗄️ DATABASE (Neon PostgreSQL) — REQUIRED
# =============================================
# Pooled connection (for app queries)
DATABASE_URL="postgresql://username:password@ep-xxxx-xxxx-123456.ap-south-1.aws.neon.tech/coaching_saas?sslmode=require&pgbouncer=true"
# Direct connection (for migrations)
DIRECT_URL="postgresql://username:password@ep-xxxx-xxxx-123456.ap-south-1.aws.neon.tech/coaching_saas?sslmode=require"

# =============================================
# 🔐 AUTHENTICATION — REQUIRED
# =============================================
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-min-32-chars"
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# =============================================
# 🤖 AI SERVICES — OpenAI + Gemini + Groq
# =============================================
# OpenAI (GPT-4) — Question generation, content creation
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Google Gemini — Performance analysis, AI insights
GEMINI_API_KEY="AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx"

# Groq (Llama/Mixtral) — Fast inference, chatbot replies
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# =============================================
# 💳 RAZORPAY PAYMENT GATEWAY — REQUIRED
# =============================================
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxxxxxxxxxxxxxxxxxx"
RAZORPAY_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxx"

# =============================================
# 📧 EMAIL / SMTP — For Notifications & Alerts
# =============================================
# Option 1: Gmail SMTP
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"   (NOT your Gmail password, use App Password)

# Option 2: Resend (Modern email API)
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Option 3: SendGrid
# SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Active config — uncomment your choice:
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="CoachPro <noreply@coachpro.in>"

# =============================================
# 💬 WHATSAPP API — For Parent Communication
# =============================================
# Option 1: Meta/Facebook WhatsApp Business API (Official)
# Get from: developers.facebook.com → WhatsApp → API Setup
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_VERIFY_TOKEN="coachpro-webhook-verify-token"
WHATSAPP_API_VERSION="v21.0"

# Option 2: Twilio WhatsApp API
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# Option 3: Wati.io (India-focused WhatsApp API)
# WATI_API_KEY=""
# WATI_API_URL="https://live-server-xxxx.wati.io"

# =============================================
# 📱 SMS API — For OTP & Alerts
# =============================================
# Option 1: MSG91 (Popular in India)
MSG91_AUTH_KEY=""
MSG91_SENDER_ID="COACHP"
MSG91_TEMPLATE_ID=""
MSG91_ROUTE="4"

# Option 2: Twilio SMS
# TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_AUTH_TOKEN="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# TWILIO_PHONE_NUMBER="+1xxxxxxxxxx"

# Option 3: Fast2SMS (Cheapest for India)
# FAST2SMS_API_KEY=""

# =============================================
# 📤 FILE UPLOAD / STORAGE (Optional)
# =============================================
# Cloudinary — For student photos, ID proofs, receipts
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# OR use AWS S3
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_S3_BUCKET=""
# AWS_REGION="ap-south-1"

# =============================================
# 🌐 APP CONFIG
# =============================================
NEXT_PUBLIC_APP_NAME="CoachPro"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NODE_ENV="production"
