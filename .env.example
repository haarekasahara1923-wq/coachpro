# ============================================
# Neon PostgreSQL Database
# ============================================
# Pooled connection (use for app queries)
DATABASE_URL="postgresql://username:password@ep-xxxx-xxxx-123456.ap-south-1.aws.neon.tech/coaching_saas?sslmode=require&pgbouncer=true"
# Direct connection (use for migrations)
DIRECT_URL="postgresql://username:password@ep-xxxx-xxxx-123456.ap-south-1.aws.neon.tech/coaching_saas?sslmode=require"

# ============================================
# Authentication
# ============================================
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-refresh-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"

# ============================================
# Optional: AI Services
# ============================================
OPENAI_API_KEY=""
GROQ_API_KEY=""

# ============================================
# Optional: WhatsApp API
# ============================================
WHATSAPP_API_KEY=""
WHATSAPP_PHONE_ID=""
